{{- /* zsh doesn't render the prompt — starship does. No color math needed here. */ -}}
# ~/.zshrc — generated by chezmoi
# =============================================================================

# ─── PATH (OS-aware) ──────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
# macOS — Homebrew (Apple Silicon first, fallback Intel)
if [[ -d /opt/homebrew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -d /usr/local/Homebrew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi
{{- else if eq .chezmoi.os "linux" -}}
# Linux — Linuxbrew if installed, else standard paths
if [[ -d /home/linuxbrew/.linuxbrew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
{{- end }}

# ─── Locale & editor ──────────────────────────────────────────────────────────
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR=nvim
export VISUAL=nvim

# ─── History (fallback — atuin takes over Ctrl-R) ─────────────────────────────
HISTFILE="$HOME/.zsh_history"
HISTSIZE=1000000
SAVEHIST=1000000
setopt EXTENDED_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY

# ─── Misc shell behaviour ─────────────────────────────────────────────────────
setopt INTERACTIVE_COMMENTS      # allow # comments at the prompt (like bash)
setopt AUTO_CD                   # typing a dir name cd's into it
setopt AUTO_PUSHD                # cd pushes onto the dir stack
setopt PUSHD_IGNORE_DUPS
setopt EXTENDED_GLOB             # **/* and friends

# ─── Word boundaries & keybindings ────────────────────────────────────────────
# Word style "bash" = only [a-zA-Z0-9] count as word chars; everything else
# (including / . _ - : etc.) is a separator. So Option+Backspace on
# "foo.bar/baz_qux" deletes "qux", then "_", then "baz", etc.
autoload -U select-word-style
select-word-style bash

# Option+arrows / Option+Backspace / Ctrl+W / Ctrl+U
bindkey '^[^?'    backward-kill-word     # Option+Backspace  (Esc + DEL)
bindkey '^[^H'    backward-kill-word     # Option+Backspace  (Esc + BS — some terminals)
bindkey '^[b'     backward-word          # Option+B  / Option+Left
bindkey '^[f'     forward-word           # Option+F  / Option+Right
bindkey '^[d'     kill-word              # Option+D  (forward kill word)
bindkey '^[[1;3D' backward-word          # Option+Left  (iTerm2 default)
bindkey '^[[1;3C' forward-word           # Option+Right (iTerm2 default)
bindkey '^W'      backward-kill-word     # Ctrl+W
bindkey '^U'      kill-whole-line        # Ctrl+U — wipes the ENTIRE line

# ─── zinit (plugin manager) ───────────────────────────────────────────────────
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  mkdir -p "$(dirname "$ZINIT_HOME")"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

# Plugins — turbo mode = loaded lazily after first prompt
# (zsh-autosuggestions self-registers via precmd; no atload needed)
zinit wait lucid for \
  atinit"ZINIT[COMPINIT_OPTS]=-C; zicompinit; zicdreplay" \
    zdharma-continuum/fast-syntax-highlighting \
    zsh-users/zsh-autosuggestions \
  blockf atpull'zinit creinstall -q .' \
    zsh-users/zsh-completions

zinit wait lucid for \
  Aloxaf/fzf-tab

# ─── Completion styling ───────────────────────────────────────────────────────
zstyle ':completion:*' menu no
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always "$realpath" 2>/dev/null || eza --color=always "$realpath"'
zstyle ':fzf-tab:*' switch-group ',' '.'

# ─── Tool integrations ────────────────────────────────────────────────────────
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
command -v zoxide   >/dev/null 2>&1 && eval "$(zoxide init zsh)"            # gives `z` and `zi`
command -v direnv   >/dev/null 2>&1 && eval "$(direnv hook zsh)"
command -v atuin    >/dev/null 2>&1 && eval "$(atuin init zsh --disable-up-arrow)"
command -v mise     >/dev/null 2>&1 && eval "$(mise activate zsh)"

# fzf keybindings & fuzzy completion
if command -v fzf >/dev/null 2>&1; then
  [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]] && source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
  [[ -f /opt/homebrew/opt/fzf/shell/completion.zsh   ]] && source /opt/homebrew/opt/fzf/shell/completion.zsh
  [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
  [[ -f /usr/share/doc/fzf/examples/completion.zsh   ]] && source /usr/share/doc/fzf/examples/completion.zsh
fi

# ─── Aliases ──────────────────────────────────────────────────────────────────
command -v eza >/dev/null 2>&1 && {
  alias ls='eza --group-directories-first --icons=auto'
  alias ll='eza -l --group-directories-first --icons=auto --git'
  alias la='eza -la --group-directories-first --icons=auto --git'
  alias lt='eza --tree --level=2 --icons=auto'
}
command -v bat  >/dev/null 2>&1 && alias cat='bat --paging=never --style=plain'
command -v rg   >/dev/null 2>&1 && alias grep='rg'
alias g='git'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'
alias lg='lazygit'

# ─── Local overrides (not versioned) ──────────────────────────────────────────
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
