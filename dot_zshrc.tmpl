{{- /* zsh doesn't render the prompt — starship does. No color math needed here. */ -}}
# ~/.zshrc — generated by chezmoi
# =============================================================================

# ─── PATH (OS-aware) ──────────────────────────────────────────────────────────
{{ if eq .chezmoi.os "darwin" -}}
# macOS — Homebrew (Apple Silicon first, fallback Intel)
if [[ -d /opt/homebrew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -d /usr/local/Homebrew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi
{{- else if eq .chezmoi.os "linux" -}}
# Linux — Linuxbrew if installed, else standard paths
if [[ -d /home/linuxbrew/.linuxbrew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
{{- end }}

# ─── Locale & editor ──────────────────────────────────────────────────────────
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR=nvim
export VISUAL=nvim

# ─── History (fallback — atuin takes over Ctrl-R) ─────────────────────────────
HISTFILE="$HOME/.zsh_history"
HISTSIZE=1000000
SAVEHIST=1000000
setopt EXTENDED_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY

# ─── Misc shell behaviour ─────────────────────────────────────────────────────
setopt INTERACTIVE_COMMENTS      # allow # comments at the prompt (like bash)
setopt AUTO_CD                   # typing a dir name cd's into it
setopt AUTO_PUSHD                # cd pushes onto the dir stack
setopt PUSHD_IGNORE_DUPS
setopt EXTENDED_GLOB             # **/* and friends

# ─── Word boundaries & keybindings ────────────────────────────────────────────
# Word style "bash" = only [a-zA-Z0-9] count as word chars; everything else
# (including / . _ - : etc.) is a separator. So Option+Backspace on
# "foo.bar/baz_qux" deletes "qux", then "_", then "baz", etc.
autoload -U select-word-style
select-word-style bash

# Option+arrows / Option+Backspace / Ctrl+W / Ctrl+U
bindkey '^[^?'    backward-kill-word     # Option+Backspace  (Esc + DEL)
bindkey '^[^H'    backward-kill-word     # Option+Backspace  (Esc + BS — some terminals)
bindkey '^[b'     backward-word          # Option+B  / Option+Left
bindkey '^[f'     forward-word           # Option+F  / Option+Right
bindkey '^[d'     kill-word              # Option+D  (forward kill word)
bindkey '^[[1;3D' backward-word          # Option+Left  (iTerm2 default)
bindkey '^[[1;3C' forward-word           # Option+Right (iTerm2 default)
bindkey '^A'      beginning-of-line      # Ctrl+A
bindkey '^E'      end-of-line            # Ctrl+E
bindkey '^W'      backward-kill-word     # Ctrl+W
bindkey '^U'      kill-whole-line        # Ctrl+U — wipes the ENTIRE line


# ─── zinit (plugin manager) ───────────────────────────────────────────────────
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ ! -d "$ZINIT_HOME" ]]; then
  mkdir -p "$(dirname "$ZINIT_HOME")"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi
source "${ZINIT_HOME}/zinit.zsh"

# Plugins — turbo mode (lazy loaded after first prompt).
# CRITICAL ORDER (per fzf-tab and fast-syntax-highlighting docs):
#   1. compinit
#   2. fzf-tab   — must come AFTER compinit, BEFORE widget-wrapping plugins
#   3. fast-syntax-highlighting, autosuggestions, history-substring-search
#   4. zsh-completions
# We enforce the order with wait'0a', '0b', '0c' suffixes.

# compinit — run early so compdef is available for gh, terraform, etc.
autoload -Uz compinit && compinit -C

# Stage a — fzf-tab (must come after compinit)
zinit wait'0a' lucid for \
    Aloxaf/fzf-tab

# Stage b — widget-wrapping plugins (must come after fzf-tab)
# history-substring-search bindings go in atload so the widget exists first.
zinit wait'0b' lucid for \
  zdharma-continuum/fast-syntax-highlighting \
  zsh-users/zsh-autosuggestions \
  atload"bindkey '^[[A' history-substring-search-up;
         bindkey '^[[B' history-substring-search-down;
         bindkey '^P'   history-substring-search-up;
         bindkey '^N'   history-substring-search-down" \
    zsh-users/zsh-history-substring-search

# Stage c — extra completions (registered after everything else)
zinit wait'0c' lucid blockf atpull'zinit creinstall -q .' for \
  zsh-users/zsh-completions

# ─── Completion styling ───────────────────────────────────────────────────────
[[ -z "$LS_COLORS" ]] && {
  command -v dircolors >/dev/null 2>&1 && eval "$(dircolors -b)" \
    || export LS_COLORS='di=1;34:ln=36:so=35:pi=33:ex=32:bd=33;01:cd=33;01:su=31;01:sg=31;01:tw=34;01:ow=34;01'
}
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' menu no
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color=always "$realpath" 2>/dev/null || eza --color=always "$realpath"'
zstyle ':fzf-tab:*' switch-group ',' '.'

# ─── Tool integrations ────────────────────────────────────────────────────────
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
command -v zoxide   >/dev/null 2>&1 && eval "$(zoxide init zsh)"            # gives `z` and `zi`
command -v direnv   >/dev/null 2>&1 && eval "$(direnv hook zsh)"
command -v atuin    >/dev/null 2>&1 && eval "$(atuin init zsh --disable-up-arrow)"
command -v mise     >/dev/null 2>&1 && eval "$(mise activate zsh)"

# fzf keybindings & fuzzy completion
if command -v fzf >/dev/null 2>&1; then
  [[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]] && source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
  [[ -f /opt/homebrew/opt/fzf/shell/completion.zsh   ]] && source /opt/homebrew/opt/fzf/shell/completion.zsh
  [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
  [[ -f /usr/share/doc/fzf/examples/completion.zsh   ]] && source /usr/share/doc/fzf/examples/completion.zsh
fi

# ─── Aliases ──────────────────────────────────────────────────────────────────
command -v eza >/dev/null 2>&1 && {
  alias ls='eza --group-directories-first --icons=auto'
  alias ll='eza -l --group-directories-first --icons=auto --git'
  alias la='eza -la --group-directories-first --icons=auto --git'
  alias lt='eza --tree --level=2 --icons=auto'
}
command -v bat  >/dev/null 2>&1 && alias cat='bat --paging=never --style=plain'
command -v rg   >/dev/null 2>&1 && alias grep='rg'

# Git
alias g='git'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'
alias lg='lazygit'

# Tmux
alias t='tmux'
alias ta='tmux attach'
alias tn='tmux new -s'

# ─── Completions for CLIs that provide their own ──────────────────────────────
command -v gh         >/dev/null 2>&1 && eval "$(gh completion -s zsh)"
command -v terraform  >/dev/null 2>&1 && autoload -U +X bashcompinit && bashcompinit && complete -o nospace -C terraform terraform

# ─── Auto-venv on cd (Python) ─────────────────────────────────────────────────
# Sources venv/bin/activate or .venv/bin/activate when entering a project,
# deactivates when leaving. For more flexibility (AWS profiles, env vars,
# secrets per project), consider migrating to direnv with .envrc files.
_auto_venv() {
  if [[ -f "venv/bin/activate" ]]; then
    [[ "$VIRTUAL_ENV" != "$PWD/venv" ]] && source venv/bin/activate
  elif [[ -f ".venv/bin/activate" ]]; then
    [[ "$VIRTUAL_ENV" != "$PWD/.venv" ]] && source .venv/bin/activate
  elif [[ -n "$VIRTUAL_ENV" ]]; then
    # Left the project tree — deactivate if we're not inside another venv's tree
    [[ "$PWD" != "$VIRTUAL_ENV"/* ]] && deactivate 2>/dev/null
  fi
}
autoload -U add-zsh-hook
add-zsh-hook chpwd _auto_venv
_auto_venv   # run once on shell start

# ─── Node / Python / Go / Rust versions — via mise ────────────────────────────
# mise is activated earlier via `eval "$(mise activate zsh)"`. To use it:
#   mise use node@lts           # pin Node LTS globally
#   mise use node@20            # or in a project, creates .tool-versions
#   mise use python@3.12        # same for Python
# See: https://mise.jdx.dev/getting-started.html

# ─── Local overrides (not versioned) ──────────────────────────────────────────
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
